# ─────────────────────────────────────────────────────────────
# TalentHub — variables d'environnement (MODÈLE — sans secrets)
# Copier ce fichier en `.env` puis remplir avec tes vraies valeurs.
# ⚠️ Ne jamais mettre de vraies clés ici : ce fichier est versionné dans git.
# ─────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
# Clé service role : SERVEUR UNIQUEMENT, ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- Base de données Postgres Supabase (Project Settings → Database → Connection string) ---
# DATABASE_URL : Transaction pooler (port 6543, pgbouncer) — exécution de l'app
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL : Session pooler (port 5432) — migrations Prisma
# ⚠️ NE PAS utiliser db.<ref>.supabase.co:5432 (IPv6-only → erreur P1001). Utiliser le pooler.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# --- Emails transactionnels (Resend) ---
RESEND_API_KEY="<resend-api-key>"
RESEND_FROM_EMAIL="TalentHub <no-reply@tondomaine.com>"

# --- Application ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
